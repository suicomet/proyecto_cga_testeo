# Debug Settings
DEBUG=True  # Set to False in production
DJANGO_SECRET_KEY=tu-secreto-aqui-cambiar-en-produccion

# Host Settings
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CSRF_TRUSTED_ORIGINS=https://*.railway.app

# Database Settings (PostgreSQL)
# For Railway: Use DATABASE_URL provided automatically
# For local development: Use individual variables
DATABASE_URL=postgresql://user:password@host:port/dbname
DB_NAME=panaderia_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Railway Environment (automatically set by Railway)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_STATIC_URL=your-railway-url